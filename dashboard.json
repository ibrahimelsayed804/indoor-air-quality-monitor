    {
        "id": "1376416b773b1bcc",
        "type": "function",
        "z": "87b8ba54e8cb2b27",
        "name": "Build AVG + Velocity SQL",
        "func": "msg.topic = `SELECT\n  ROUND(AVG(co2),1)         AS avg_co2,\n  ROUND(AVG(temperature),1) AS avg_temp,\n  ROUND(AVG(humidity),1)    AS avg_hum,\n  ( SELECT air_velocity FROM fs3000 ORDER BY \\`timestamp\\` DESC LIMIT 1 ) AS air_velocity\nFROM (\n  SELECT co2, temperature, humidity FROM (SELECT co2, temperature, humidity FROM scd41_1  ORDER BY \\`timestamp\\` DESC LIMIT 1) t1\n  UNION ALL\n  SELECT co2, temperature, humidity FROM (SELECT co2, temperature, humidity FROM scd41_2  ORDER BY \\`timestamp\\` DESC LIMIT 1) t2\n  UNION ALL\n  SELECT co2, temperature, humidity FROM (SELECT co2, temperature, humidity FROM scd41_3  ORDER BY \\`timestamp\\` DESC LIMIT 1) t3\n  UNION ALL\n  SELECT co2, temperature, humidity FROM (SELECT co2, temperature, humidity FROM scd41_4  ORDER BY \\`timestamp\\` DESC LIMIT 1) t4\n  UNION ALL\n  SELECT co2, temperature, humidity FROM (SELECT co2, temperature, humidity FROM scd41_5  ORDER BY \\`timestamp\\` DESC LIMIT 1) t5\n  UNION ALL\n  SELECT co2, temperature, humidity FROM (SELECT co2, temperature, humidity FROM scd41_6  ORDER BY \\`timestamp\\` DESC LIMIT 1) t6\n  UNION ALL\n  SELECT co2, temperature, humidity FROM (SELECT co2, temperature, humidity FROM scd41_7  ORDER BY \\`timestamp\\` DESC LIMIT 1) t7\n  UNION ALL\n  SELECT co2, temperature, humidity FROM (SELECT co2, temperature, humidity FROM scd41_8  ORDER BY \\`timestamp\\` DESC LIMIT 1) t8\n  UNION ALL\n  SELECT co2, temperature, humidity FROM (SELECT co2, temperature, humidity FROM scd41_9  ORDER BY \\`timestamp\\` DESC LIMIT 1) t9\n  UNION ALL\n  SELECT co2, temperature, humidity FROM (SELECT co2, temperature, humidity FROM scd41_10 ORDER BY \\`timestamp\\` DESC LIMIT 1) t10\n) AS combined;`;\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 430,
        "y": 140,
        "wires": [
            [
                "c0bcc9a2fa946ecb"
            ]
        ]
    },
    {
        "id": "c0bcc9a2fa946ecb",
        "type": "mysql",
        "z": "87b8ba54e8cb2b27",
        "mydb": "99e528a7a3798b5b",
        "name": "Query AVG + Velocity",
        "x": 700,
        "y": 140,
        "wires": [
            [
                "0cbb87cabd3cb925"
            ]
        ]
    },
    {
        "id": "0cbb87cabd3cb925",
        "type": "function",
        "z": "87b8ba54e8cb2b27",
        "name": "Parse → Gauges + Multi-Series Chart",
        "func": "// Outputs (preserves old numbering):\n// 1?4  gauges/levels: CO2, Temp, Hum, Vel\n// 5?8  (placeholders for removed KPI text)\n// 9?12 charts: Temp, Hum, Vel, CO2\n\nconst row = (Array.isArray(msg.payload) && msg.payload[0]) ? msg.payload[0] : {};\n\nconst co2 = Number(row.avg_co2 ?? 0);\nconst tmp = Number(row.avg_temp ?? 0);\nconst hum = Number(row.avg_hum ?? 0);\nlet vel = Number(row.air_velocity ?? row.airflow_ms ?? row.avg_velocity ?? 0);\nif (!Number.isFinite(vel)) vel = 0;\nconst vel2 = Math.round(vel * 100) / 100;\n\n// Gauges / level bars\nconst gCO2 = { payload: co2 };\nconst gTMP = { payload: tmp };\nconst gHUM = { payload: hum };\nconst gVEL = { payload: vel2 };\n\n// Charts (one series each)\nconst cTMP = { topic: \"Temperature\", payload: tmp };\nconst cHUM = { topic: \"Humidity\",    payload: hum };\nconst cVEL = { topic: \"Velocity\",     payload: vel2 };\nconst cCO2 = { topic: \"CO2\",          payload: co2 };\n\n// Keep 5?8 so existing wires don?t break\nreturn [gCO2, gTMP, gHUM, gVEL, null, null, null, null, cTMP, cHUM, cVEL, cCO2];",
