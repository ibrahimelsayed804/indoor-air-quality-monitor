    {
        "id": "1294f17c950abd4e",
        "type": "inject",
        "z": "87b8ba54e8cb2b27",
        "name": "Every 1s",
        "props": [],
        "repeat": "1",
        "crontab": "",
        "once": true,
        "onceDelay": "1",
